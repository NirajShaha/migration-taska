{
  "info": {
    "_postman_id": "wvta-coc-management",
    "name": "WVTA CoC Management System",
    "description": "API collection for WVTA Certificate of Conformity Management System\n\nBase URL: http://localhost:8080/api\n\nEndpoints:\n- Type Management (HA100T)\n- Variant Management (HA200T)\n- VAC Fields (HA300T)\n- COC Fields (HA900T)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Type Management",
      "item": [
        {
          "name": "Lookup Type",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/types/lookup?model=A&type=ABC1&startDate=2024-01-01&endDate=2025-12-31&manf=M",
              "host": ["{{base_url}}", "/types/lookup"],
              "query": [
                {
                  "key": "model",
                  "value": "A",
                  "description": "Vehicle model (1 char)"
                },
                {
                  "key": "type",
                  "value": "ABC1",
                  "description": "Type code (max 4 chars)"
                },
                {
                  "key": "startDate",
                  "value": "2024-01-01",
                  "description": "Start date (YYYY-MM-DD)"
                },
                {
                  "key": "endDate",
                  "value": "2025-12-31",
                  "description": "End date (YYYY-MM-DD)"
                },
                {
                  "key": "manf",
                  "value": "M",
                  "description": "Manufacturer (1 char)"
                }
              ]
            },
            "description": "Read type by composite key (maps READ HATTYP from COBOL)"
          },
          "response": []
        },
        {
          "name": "Update Type Approval",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"typModel\": \"A\",\n  \"typType\": \"ABC1\",\n  \"typStartDate\": \"2024-01-01\",\n  \"typEndDate\": \"2025-12-31\",\n  \"typManf\": \"M\",\n  \"typApprovalNo\": \"EU2024/001\",\n  \"typApprDate\": \"2024-03-15\",\n  \"typSmallSeries\": \"Y\",\n  \"userId\": \"USER001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/types/A/ABC1/2024-01-01/2025-12-31/M/approval",
              "host": ["{{base_url}}", "/types"],
              "path": [
                "A",
                "ABC1",
                "2024-01-01",
                "2025-12-31",
                "M",
                "approval"
              ]
            },
            "description": "Update type approval number, date, and small series indicator (maps HA100T-UPDATE-APPROVAL-NO)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Variant Management",
      "item": [
        {
          "name": "Lookup Variant",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/variants/lookup?model=A&type=ABC1&startDate=2024-01-01&endDate=2025-12-31&variant=VAR001&manf=M",
              "host": ["{{base_url}}", "/variants/lookup"],
              "query": [
                {
                  "key": "model",
                  "value": "A",
                  "description": "Vehicle model (1 char)"
                },
                {
                  "key": "type",
                  "value": "ABC1",
                  "description": "Type code (max 4 chars)"
                },
                {
                  "key": "startDate",
                  "value": "2024-01-01",
                  "description": "Start date (YYYY-MM-DD)"
                },
                {
                  "key": "endDate",
                  "value": "2025-12-31",
                  "description": "End date (YYYY-MM-DD)"
                },
                {
                  "key": "variant",
                  "value": "VAR001",
                  "description": "Variant code (max 6 chars)"
                },
                {
                  "key": "manf",
                  "value": "M",
                  "description": "Manufacturer (1 char)"
                }
              ]
            },
            "description": "Read variant by composite key (maps READ HATVAR from COBOL)"
          },
          "response": []
        },
        {
          "name": "Update Variant",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"varModel\": \"A\",\n  \"varType\": \"ABC1\",\n  \"varStartDate\": \"2024-01-01\",\n  \"varEndDate\": \"2025-12-31\",\n  \"varVariant\": \"VAR001\",\n  \"varManf\": \"M\",\n  \"varEngine\": \"2.0L-DIESEL\",\n  \"varAxlesCocVal\": \"2,LongitudinalALL,Mechanical\",\n  \"varCocAnnex\": \"EU2023-670\",\n  \"varChipData\": \"N\",\n  \"varGenTyrList\": \"Y\",\n  \"varNewmodActmasInd\": \"Y\",\n  \"userId\": \"USER001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/variants/A/ABC1/2024-01-01/2025-12-31/VAR001/M",
              "host": ["{{base_url}}", "/variants"],
              "path": [
                "A",
                "ABC1",
                "2024-01-01",
                "2025-12-31",
                "VAR001",
                "M"
              ]
            },
            "description": "Update variant engine, axles, and CoC content (maps HA200T-UPDATE-POWERED-AXLE)"
          },
          "response": []
        },
        {
          "name": "Validate Powered Axles",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/variants/validate-powered-axles?poweredAxles=2&position=LongitudinalALL&interconnection=Mechanical",
              "host": ["{{base_url}}", "/variants/validate-powered-axles"],
              "query": [
                {
                  "key": "poweredAxles",
                  "value": "2",
                  "description": "Number of powered axles"
                },
                {
                  "key": "position",
                  "value": "LongitudinalALL",
                  "description": "Position configuration (optional)"
                },
                {
                  "key": "interconnection",
                  "value": "Mechanical",
                  "description": "Interconnection type (optional)"
                }
              ]
            },
            "description": "Validate powered axles requirement - if powered axles provided, position and interconnection are required"
          },
          "response": []
        }
      ]
    },
