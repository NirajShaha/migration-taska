# WVTA CoC Management System - Frontend Environment Variables

# NextAuth Configuration (CRITICAL - must be set)
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=super-secret-key-min-32-chars-for-production-please-change-this
NEXTAUTH_URL=http://localhost:3000

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8081

# Application Settings
NEXT_PUBLIC_APP_NAME=WVTA CoC Management System
NEXT_PUBLIC_APP_VERSION=1.0.0
